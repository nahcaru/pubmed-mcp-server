{
  "name": "pubmed-mcp-server",
  "version": "2.7.6",
  "description": "Search PubMed/Europe PMC, fetch articles and full text (PMC/EPMC/Unpaywall), citations, MeSH terms.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/pubmed-mcp-server#readme",
  "repository": "https://github.com/cyanheads/pubmed-mcp-server",
  "license": "Apache-2.0",
  "mcpServers": {
    "pubmed-mcp-server": {
      "command": "npx",
      "args": ["-y", "@cyanheads/pubmed-mcp-server"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio",
        "NCBI_API_KEY": "",
        "NCBI_ADMIN_EMAIL": "",
        "UNPAYWALL_EMAIL": ""
      }
    }
  }
}
